# Webhook do Make.com para receber os dados das escolas
WEBHOOK_URL=https://hook.make.com/seuwebhook

# Termo de busca no Google Maps
SEARCH_QUERY=escola infantil Cabo Frio

# Filtrar apenas resultados da cidade selecionada
CITY_FILTER=Cabo Frio

# Limite máximo de resultados carregados
MAX_RESULTS=500

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account-key.json
